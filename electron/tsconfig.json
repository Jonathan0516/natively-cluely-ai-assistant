{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "composite": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "rootDir": "..",
    "outDir": "../dist-electron",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    "../premium/electron/**/*.ts"
  ],
  "exclude": [
    "db/seedDemo.ts",
    "db/test-db.ts"
  ]
}
